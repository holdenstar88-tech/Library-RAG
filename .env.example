APP_NAME=Smart Campus Library RAG
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
METADATA_DB_PATH=data/processed/library_metadata.sqlite

MILVUS_URI=
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=180
MILVUS_CONNECT_TIMEOUT=180
MILVUS_COLLECTION=library_books
MILVUS_DROP_OLD=false

API_KEY=

EMBEDDING_BACKEND=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DEVICE=cpu
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSIONS=1024

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

CHAT_HISTORY_SIZE=6
SEARCH_TOP_K=3
RERANK_TOP_K=3
SIMILARITY_THRESHOLD=0.65
HYBRID_BM25_WEIGHT=0.45
HYBRID_VECTOR_WEIGHT=0.55
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=120
